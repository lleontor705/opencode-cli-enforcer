{
  "name": "opencode-cli-enforcer",
  "version": "1.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "description": "OpenCode plugin for resilient multi-LLM CLI orchestration (Claude, Gemini, Codex) with circuit breaker, retry, fallback, and cross-platform support",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "cli",
    "llm",
    "multi-llm",
    "claude",
    "gemini",
    "codex",
    "circuit-breaker",
    "orchestration"
  ],
  "author": "lleontor705",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lleontor705/opencode-cli-enforcer.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.26",
    "cockatiel": "^3.2.1",
    "execa": "^9.6.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.3.5"
  },
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bun x tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  }
}