{
  "name": "opencode-cli-enforcer",
  "version": "1.0.1",
  "description": "OpenCode plugin for resilient multi-LLM CLI orchestration (Claude, Gemini, Codex) with circuit breaker, retry, fallback, and cross-platform support",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "cli",
    "llm",
    "multi-llm",
    "claude",
    "gemini",
    "codex",
    "circuit-breaker",
    "orchestration"
  ],
  "engines": {
    "bun": ">=1.3.5",
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "author": "lleontor705",
  "repository": {
    "type": "git",
    "url": "https://github.com/lleontor705/opencode-cli-enforcer.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.26",
    "execa": "^9.6.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsup --dts-only",
    "prepublishOnly": "npm run build && npm test",
    "clean": "tsup --clean"
  }
}
