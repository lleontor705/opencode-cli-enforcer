{
  "name": "opencode-cli-enforcer",
  "version": "1.0.1",
  "description": "OpenCode plugin for resilient multi-LLM CLI orchestration (Claude, Gemini, Codex) with circuit breaker, retry, fallback, and cross-platform support",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "cli",
    "llm",
    "multi-llm",
    "claude",
    "gemini",
    "codex",
    "circuit-breaker",
    "orchestration"
  ],
  "engines": {
    "bun": ">=1.3.5",
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "author": "lleontor705",
  "repository": {
    "type": "git",
    "url": "https://github.com/lleontor705/opencode-cli-enforcer.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.26",
    "execa": "^9.6.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target bun",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bun build src/index.ts --no-bundle --outdir /dev/null",
    "prepublishOnly": "npm run build && npm test",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive:true, force:true})\""
  }
}
