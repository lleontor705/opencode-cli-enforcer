{
  "name": "opencode-cli-enforcer",
  "version": "1.3.1",
  "description": "OpenCode plugin for resilient multi-LLM CLI orchestration (Claude, Gemini, Codex) with circuit breaker, retry, fallback, and cross-platform support",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "cli",
    "llm",
    "multi-llm",
    "claude",
    "gemini",
    "codex",
    "circuit-breaker",
    "orchestration"
  ],
  "author": "lleontor705",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lleontor705/opencode-cli-enforcer.git"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.26",
    "cockatiel": "^3.2.1",
    "execa": "^9.6.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.3.5"
  },
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "prepare": "husky",
    "prepublishOnly": "bun run build && bun test"
  }
}
