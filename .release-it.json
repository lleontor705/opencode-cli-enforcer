{
  "$schema": "https://unpkg.com/release-it@latest/schema.json",
  "git": {
    "commitMessage": "chore: release ${version}",
    "tagAnnotation": "Release ${version}",
    "tagName": "v${version}"
  },
  "npm": {
    "publish": true,
    "skipChecks": false
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "draft": false,
    "preRelease": false
  },
  "plugins": [
    "@release-it/bumper"
  ]
}
